{
  "name": "Room",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique room/project id"
    },
    "owner_id": {
      "type": "string",
      "description": "User id of the owner"
    },
    "name": {
      "type": "string",
      "description": "Room/project name"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the project"
    },
    "language": {
      "type": "string",
      "enum": [
        "javascript",
        "python",
        "rust",
        "typescript",
        "go",
        "cpp"
      ],
      "default": "javascript",
      "description": "Primary programming language"
    },
    "status": {
      "type": "string",
      "enum": [
        "idle",
        "running",
        "archived"
      ],
      "default": "idle"
    },
    "created_at": {
      "type": "string",
      "description": "Creation timestamp"
    }
  },
  "required": [
    "name"
  ]
}